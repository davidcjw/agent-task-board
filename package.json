{
  "name": "agent-task-board",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:local": "next start -H 127.0.0.1",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check:agent": "node agent/check.mjs",
    "scout": "node --env-file-if-exists=.env agent/scout.mjs",
    "scout:install": "node --env-file-if-exists=.env agent/launchd/scout-install.mjs",
    "scout:uninstall": "node agent/launchd/scout-install.mjs --uninstall",
    "dispatcher": "node --env-file-if-exists=.env agent/dispatcher.mjs",
    "watcher": "node --env-file-if-exists=.env agent/merge-watcher.mjs",
    "history": "node agent/history.mjs",
    "telegram": "node --env-file-if-exists=.env agent/telegram-bot.mjs",
    "mcp": "node --env-file-if-exists=.env agent/mcp-server.mjs",
    "agents": "node --env-file-if-exists=.env agent/launch.mjs",
    "agents:install": "node --env-file-if-exists=.env agent/launchd/install.mjs",
    "agents:uninstall": "node agent/launchd/install.mjs --uninstall"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "geist": "^1.7.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
