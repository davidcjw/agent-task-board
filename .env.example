# ── Agent Task Board — agent layer config ─────────────────────────────────
# Copy to .env (or export in your shell) before running the dispatcher / bot /
# MCP server. The web app itself needs none of these in local mode.

# Run the UI against the live server-backed board so you watch agents work it.
# (Set in .env.local for `next dev`.) Omit/leave unset for local-first mode.
NEXT_PUBLIC_BOARD_MODE=api

# Where the agent layer reaches the board (the running Next app). `npm run agents`
# also binds the board to this url's port (e.g. :3738), so this is the single
# knob for the port — no separate PORT needed.
BOARD_URL=http://localhost:3000

# Optional shared secret. If set, EVERY /api route (board, tasks, claim,
# result, cancel) requires `Authorization: Bearer <token>` and 401s otherwise.
# Unset = open (local-first default). The agent-layer clients send it automatically.
AGENT_TOKEN=
# The browser UI in api mode needs the same token — mirror it here (set in
# .env.local; it's inlined into the client bundle at build time, so anyone who
# can load the UI can read it — trusted-network convenience, not a secret).
NEXT_PUBLIC_AGENT_TOKEN=

# ── Dispatcher ────────────────────────────────────────────────────────────
# Actually execute runner commands. UNSET = dry-run (safe; reports only).
AGENT_EXECUTE=
# Path to your routing config (agent label -> runner). Defaults to agent/routes.json
# then agent/routes.example.json.
AGENT_ROUTES=
# Base dir for a route's "{repo}" cwd. A task tagged `repo:<name>` runs in
# <AGENT_REPO_BASE>/<name>, so one route serves every repo. Default: ~/code.
AGENT_REPO_BASE=
# How many tasks to run at once (default 1). Each PR task runs in its own git
# worktree, so concurrent tasks — even on the same repo — stay isolated.
AGENT_CONCURRENCY=1
# Where per-task worktrees are created. Default: $TMPDIR/atb-worktrees.
AGENT_WORKTREE_DIR=
# Poll interval (ms) and per-task timeout (ms).
AGENT_INTERVAL=3000
AGENT_TIMEOUT=1200000
# How often (ms) the dispatcher checks the board for /cancel requests on in-flight tasks.
AGENT_CANCEL_POLL=3000

# ── Review gate (pre-PR independent review) ───────────────────────────────
# Before a PR opens, a fresh agent + the repo's own checks iterate fixes until
# the change clears the gate (checks green AND no blocking findings AND
# confidence >= threshold). Override the per-route `review` flag: 1 = force ON
# for every PR route, 0 = force OFF, unset = leave it to each route's config.
AGENT_REVIEW=
# Per-check (npm run lint/typecheck/test) kill-timeout in ms. Default 5 min.
REVIEW_CHECK_TIMEOUT=300000

# ── Merge watcher ─────────────────────────────────────────────────────────
# Moves a Review task to Done once its PR (a github.com/.../pull/N url in the
# task result) is merged, checked via `gh`. How often to poll, in ms (default 30s).
WATCHER_INTERVAL=30000

# ── Telegram ──────────────────────────────────────────────────────────────
# Create a bot with @BotFather, paste its token here. Message the bot, then
# send /id to learn TELEGRAM_CHAT_ID (where the dispatcher posts notifications).
# Setting this AUTO-STARTS the built-in inbound bot under `npm run agents` (every
# message → a queued task). Use a DEDICATED bot here — sharing a token with
# another poller (e.g. hans) 409s. Disable with `npm run agents -- --no-telegram`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Inbound allowlist: only these chats may queue tasks (comma-separated). Falls
# back to TELEGRAM_CHAT_ID when unset. Leave BOTH blank only on a trusted network
# — the bot then queues tasks from ANY chat (it warns at startup).
ALLOWED_CHAT_IDS=
