{
  "default": {
    "command": "claude",
    "args": ["-p", "{prompt}", "--output-format", "json", "--dangerously-skip-permissions"],
    "cwd": "{repo}",
    "pr": true
  },
  "Claude Code": {
    "command": "claude",
    "args": ["-p", "{prompt}", "--output-format", "json", "--dangerously-skip-permissions"],
    "cwd": "{repo}",
    "pr": true,
    "review": { "iterations": 2, "threshold": 95, "checks": ["lint", "typecheck", "test"] }
  },
  "Cursor": {
    "command": "echo",
    "args": ["Wire up a Cursor agent runner here. Task: {title}"],
    "cwd": "{repo}"
  },
  "knowledge-base": {
    "command": "claude",
    "args": [
      "-p",
      "{prompt}",
      "--agent",
      "knowledge-base",
      "--output-format",
      "json",
      "--dangerously-skip-permissions"
    ],
    "cwd": "."
  }
}
